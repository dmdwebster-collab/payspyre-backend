# Database
DATABASE_URL=postgresql+psycopg2://payspyre:your_password@localhost:5432/payspyre
DB_PASSWORD=your_password

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Didit
DIDIT_API_KEY=your_didit_api_key
DIDIT_WEBHOOK_SECRET=your_didit_webhook_secret

# Persona
PERSONA_API_KEY=your_persona_api_key
PERSONA_WEBHOOK_SECRET=your_persona_webhook_secret

# Credit Bureaus
EQUIFAX_API_KEY=your_equifax_api_key
TRANSUNION_API_KEY=your_transunion_api_key

# CORS
CORS_ORIGINS=http://localhost:3000,https://payspyre.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_REQUESTS=5
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_READ_REQUESTS=100
RATE_LIMIT_READ_WINDOW=60
RATE_LIMIT_WRITE_REQUESTS=30
RATE_LIMIT_WRITE_WINDOW=60
RATE_LIMIT_WEBHOOK_REQUESTS=1000
RATE_LIMIT_WEBHOOK_WINDOW=60

# CSRF Protection
CSRF_ENABLED=true

# Notifications
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@payspyre.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Notification Queue
NOTIFICATION_QUEUE_PROCESSING_INTERVAL=60
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAYS=5,15,30

# Webhooks
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=3

# AWS S3 Document Storage
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=payspyre-documents
AWS_REGION=us-east-1

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Observability
ENVIRONMENT=development
VERSION=0.1.0
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Observability (P8.0) — PostHog bridge for platform_events fan-out
POSTHOG_API_KEY=phc_your_project_api_key
POSTHOG_HOST=https://us.i.posthog.com
OBSERVABILITY_ENABLED=false
OBSERVABILITY_POSTHOG_ALLOWLIST=verification_completed,webhook_rejected,webhook_orphaned,notification_sent,notification_status_updated,decision_made,magic_link_issued
# Production Environment Variables Template
# Copy this file to .env.production and fill in the values

# Database (DigitalOcean Managed PostgreSQL)
DATABASE_URL=postgresql+psycopg2://payspyre:PASSWORD@db-postgresql-xxx-do-user-xxx.db.ondigitalocean.com:25060/payspyre

# JWT Security (Generate strong secrets)
JWT_SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_HERE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Didit Vendor
DIDIT_API_KEY=CHANGE_ME
DIDIT_WEBHOOK_SECRET=CHANGE_ME

# Persona Vendor
PERSONA_API_KEY=CHANGE_ME
PERSONA_WEBHOOK_SECRET=CHANGE_ME

# Credit Bureaus
EQUIFAX_API_KEY=CHANGE_ME
TRANSUNION_API_KEY=CHANGE_ME

# CORS (Comma-separated list of allowed origins)
CORS_ORIGINS=https://payspyre.com,https://www.payspyre.com

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_REQUESTS=5
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_READ_REQUESTS=100
RATE_LIMIT_READ_WINDOW=60
RATE_LIMIT_WRITE_REQUESTS=30
RATE_LIMIT_WRITE_WINDOW=60
RATE_LIMIT_WEBHOOK_REQUESTS=1000
RATE_LIMIT_WEBHOOK_WINDOW=60

# CSRF Protection
CSRF_ENABLED=true

# Notifications
RESEND_API_KEY=CHANGE_ME
RESEND_FROM_EMAIL=noreply@payspyre.com
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1234567890

# Notification Queue
NOTIFICATION_QUEUE_PROCESSING_INTERVAL=60
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAYS=5,15,30

# Webhooks
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_MAX_RETRIES=3

# AWS S3 Document Storage
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=payspyre-documents
AWS_REGION=us-east-1

# Stripe
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# Optional: Log level
LOG_LEVEL=INFO
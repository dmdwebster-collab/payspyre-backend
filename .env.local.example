# =============================================================================
# PaySpyre v2 — Supabase Database Configuration
# =============================================================================
# Copy this file to .env.local and fill in your Supabase credentials
# Source: https://supabase.com/dashboard/project/_/settings/database
#
# SUPABASE CONNECTION STRING FORMATS:
# ===================================
# Direct connection (for migrations):
#   postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
#
# Transaction pooler (for application - better for many short connections):
#   postgresql+psycopg2://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres
#
# Session pooler (for serverless/edge functions):
#   postgresql+psycopg2://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:5432/postgres
#
# WHERE TO FIND THESE:
# ===================
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Settings → Database
# 4. Scroll to "Connection string" section
# 5. Choose "URI" tab (for alembic migrations) or "Transaction" tab (for app)
# 6. Copy the connection string and replace [YOUR-PASSWORD] with your database password
# 7. Update the PROJECT_REF in this file
#
# For this MVP build, use the Direct connection (URI format) for migrations.
# =============================================================================

# Supabase Database Connection (for Alembic migrations)
DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional: Transaction pooler for application runtime (better performance)
# DATABASE_URL_POOLER=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@[PROJECT-REF].pooler.supabase.com:6543/postgres

# =============================================================================
# YOUR CREDENTIALS TO FILL IN:
# =============================================================================
# PROJECT_REF: Your Supabase project reference (found in project URL or dashboard)
# PASSWORD: Your database password (set when creating the project, or reset in Settings → Database)

# Example (DO NOT COMMIT REAL CREDENTIALS):
# DATABASE_URL=postgresql+psycopg2://postgres:my-secret-password@db.abcdefgh1234.supabase.co:5432/postgres

# =============================================================================
# Observability (P8.0) — PostHog bridge for platform_events fan-out
# =============================================================================
POSTHOG_API_KEY=phc_your_project_api_key
POSTHOG_HOST=https://us.i.posthog.com
OBSERVABILITY_ENABLED=false
OBSERVABILITY_POSTHOG_ALLOWLIST=verification_completed,webhook_rejected,webhook_orphaned,notification_sent,notification_status_updated,decision_made,magic_link_issued
